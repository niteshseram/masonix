{
  "name": "masonix-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run --filter './packages/*' build",
    "dev": "vp run --filter masonix dev",
    "docs": "vp run --filter masonix-docs dev",
    "docs:build": "vp run --filter masonix-docs... build",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "gh-release": "gh release create \"v$(node -p \"require('./packages/masonix/package.json').version\")\" --generate-notes",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "release": "pnpm build && changeset publish",
    "size": "pnpm -F masonix size",
    "tc": "vp run typecheck",
    "test": "vp test run",
    "test:coverage": "vp test --run --coverage",
    "test:watch": "vp test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^11.0.0",
    "typescript": "^5.7.0",
    "vite-plus": "latest",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@10.18.3"
}
