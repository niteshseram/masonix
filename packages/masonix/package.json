{
  "name": "masonix",
  "version": "0.4.0",
  "description": "React masonry components for responsive grids, measured layouts, and virtualized feeds",
  "keywords": [
    "grid",
    "layout",
    "masonry",
    "react",
    "ssr",
    "tailwind",
    "virtualized"
  ],
  "homepage": "https://github.com/niteshseram/masonix#readme",
  "bugs": {
    "url": "https://github.com/niteshseram/masonix/issues"
  },
  "license": "MIT",
  "author": "Nitesh Seram",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niteshseram/masonix.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./virtual": {
      "types": "./src/virtual.ts",
      "import": "./dist/virtual.mjs",
      "require": {
        "types": "./dist/virtual.d.cts",
        "default": "./dist/virtual.cjs"
      }
    }
  },
  "publishConfig": {
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./virtual": {
        "import": {
          "types": "./dist/virtual.d.mts",
          "default": "./dist/virtual.mjs"
        },
        "require": {
          "types": "./dist/virtual.d.cts",
          "default": "./dist/virtual.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && vp pack",
    "dev": "vp pack --watch",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "size": "size-limit",
    "tc": "tsc --noEmit",
    "test": "vp test",
    "test:coverage": "vp test --run --coverage",
    "test:run": "vp test --run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "5 kB"
    },
    {
      "path": "dist/virtual.mjs",
      "limit": "10 kB"
    }
  ]
}
